.container {
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.music-info {
  text-align: center;
  margin-bottom: 60rpx;
}

.music-title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.music-artist {
  font-size: 18px;
  color: #666;
}

.progress-container {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.time {
  font-size: 14px;
  color: #666;
  width: 80rpx;
}

.progress-bar {
  flex: 1;
  margin: 0 20rpx;
}

.control-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.speed-container,
.volume-container {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.speed-options {
  display: flex;
  margin-left: 20rpx;
}

.speed-option {
  padding: 10rpx 20rpx;
  margin-right: 16rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
}

.speed-option.active {
  background-color: #ff6b35;
  color: white;
}

.volume-bar {
  flex: 1;
  height: 8rpx;
  background-color: #eee;
  border-radius: 4rpx;
  margin: 0 20rpx;
  position: relative;
}

.volume-progress {
  height: 100%;
  background-color: #ff6b35;
  border-radius: 4rpx;
}

.volume-handle {
  position: absolute;
  top: -8rpx;
  width: 24rpx;
  height: 24rpx;
  background-color: #ff6b35;
  border-radius: 50%;
  transform: translateX(-50%);
}

.collect-container,
.cache-container {
  width: 100%;
  margin-top: 20rpx;
}

.collect-btn,
.cache-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 18px;
  font-weight: bold;
  background-color: #f0f0f0;
}

.collect-btn {
  margin-bottom: 20rpx;
}