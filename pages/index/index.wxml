<view class="container">
  <!-- 搜索框 -->
  <view class="search-container">
    <view class="search-input-wrapper">
      <input 
        type="text" 
        placeholder="搜索歌曲" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        class="search-input"
      />
      <view class="search-btn" bindtap="onSearchConfirm">
        搜索
      </view>
    </view>
  </view>

  <!-- 音乐列表 -->
  <view class="music-list">
    <view 
      wx:for="{{musicList}}" 
      wx:key="id"
      class="music-card"
      bindtap="playMusic"
      data-music="{{item}}"
    >
      <view class="play-btn">
        {{item.isPlaying ? '⏸' : '▶'}}
      </view>
      <view class="music-info">
        <view class="music-title">{{item.title}}</view>
        <view class="music-desc">{{item.artist}} | {{item.duration}}</view>
      </view>
      <view 
        class="collect-btn"
        bindtap="toggleCollect"
        data-id="{{item.id}}"
      >
        {{item.isCollected ? '❤️' : '🤍'}}
      </view>
    </view>
  </view>


</view>